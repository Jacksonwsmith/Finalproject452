@model Category

<h1>Delete Category</h1>

<div class="border col-md-10 mx-auto">

    <form asp-action="Delete">
        <input type="hidden" asp-for="CategoryId" />

        <div class="form-group row m-4 ">
            <label asp-for="Name" class="control-label col-md-2"> </label>
            <div>
                <input asp-for="Name" disabled class="form-control col-md-10" />
            </div>
        </div>

        <div class="form-group row-m-4">
            <label asp-for="Description" class="control-label col-md-2"> </label>
            <div>
                <input asp-for="Description" disabled class="form-control col-md-10" />
            </div>
        </div>


        <div class="form-group m-4">
            <input type="submit" value="Delete Category" class="form-control btn btn-danger" />
        </div>


    </form>

</div>