@model Category

<h1>Category Details</h1>

        <table class="table table table-bordered table striped">
            <thead>
                <tr>
                    <th>Category Id</th>
                    <th>Category Name</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.CategoryId</td>
                    <td>@Model.Name</td>
                    <td>@Model.Description</td>
                </tr>
            </tbody>
        </table>