@model Microsoft.AspNetCore.Identity.IdentityUserRole<string>

<h1>Edit User Role</h1>

<div class="border col-md-10">

    <form asp-action="EditUserRole">

        <input type="hidden" asp-for="UserId" />
        <div class="form-group">
            <label asp-for="RoleId" class="control-label"></label>
            <label class="control-label">User Email</label>
            <input value="@ViewBag.UserInfo.Email" class="form-control" />
            </div>

            <div class=" form-group m-4">
                <label class="control-label">Role</label>
                <select asp-for="RoleId" class="form-control" asp-items="@ViewBag.Roles">

                <option value="">-- Select Role --</option>

                </select>

            </div>

            <div class="form-group m-4">

            <input type="submit" value="Save" class="btn btn-primary" />
            </div>

    </form>

</div>
