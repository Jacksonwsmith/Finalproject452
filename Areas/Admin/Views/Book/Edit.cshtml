            <div>
                <select asp-for="CategoryID" class="form-control" asp-items="ViewBag.ListOfCategories">

                    <option disabled selected>Select a Category</option>

                </select>
                <span asp-validation-for="CategoryID" class="text-danger"></span>
            </div>
        </div> *@




        @* <div class="form-group m-4">
            <label asp-for="CategoryID" class="control-label col-md-2"> </label>
            <div>
                <select asp-for="CategoryID" class="form-control" asp-items="@ViewData["ListOfCategoriesVD"] as IEnumerable<SelectListItem>">

                    <option disabled selected>Select a Category</option>

                </select>
                <span asp-validation-for="CategoryID" class="text-danger"></span>
            </div>
        </div> *@






        <div class="form-group m-4">
            <label asp-for="Book.CategoryID" class="control-label col-md-2"> </label>
            <div>
                <select asp-for="Book.CategoryID" class="form-control" asp-items="@Model.ListOfCategories">

                    <option disabled selected>Select a Category</option>

                </select>
                <span asp-validation-for="Book.CategoryID" class="text-danger"></span>
            </div>
        </div>






        <div class="form-group m-4">
            <label asp-for="Book.ImgUrl" class="control-label col-md-2"> </label>
            <div>
                <input type="file" name="imgFile" class="form-control col-md-10" />
                
            </div>
        </div>







        <div class="form-group row m-4">
            <input type="submit" value="Update Book" class="form-control btn btn-outline-primary" />
        </div>
    </form>


    @section Scripts
    {

    <partial name="_ValidationScriptsPartial" />

    }

</div>
